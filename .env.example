# These are set in the Vercel dashboard (Project → Settings → Environment Variables).
# Locally, copy to .env.local for `vercel dev`.

# Neon connection string (Vercel adds this automatically if you connect Neon
# via the Vercel integration; otherwise paste it from the Neon dashboard).
DATABASE_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require

# Auth — use a long random string in production.
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d

# Default password used when a tutor creates a student without specifying one.
DEMO_PASSWORD=demo1234

# Optional: only needed if you point the frontend at a different API origin.
# VITE_API_BASE=/api
